# Environment variables for docker-compose
AIRFLOW_DATABASE_CONN=postgresql+psycopg2://airflow:airflow@lakehouse-airflow-postgres:5432/airflow
AIRFLOW_WEBSERVER_SECRET_KEY=local_lakehouse_secret
AIRFLOW_CONN_SPARK_DEFAULT=spark://spark-master:7077
AIRFLOW_CONN_TRINO_DEFAULT=trino://trino@trino:8080/iceberg

# MinIO configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=lakehouse
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
